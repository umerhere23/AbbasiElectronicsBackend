# SMTP for invoice emails (Hostinger)
# Primary: smtp.hostinger.com:465 over SSL
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your-full-email-address@example.com
SMTP_PASS=replace_with_email_password
SMTP_FROM=your-full-email-address@example.com

# Alternative: smtp.hostinger.com:587 over TLS / STARTTLS
# SMTP_PORT=587
# SMTP_SECURE=false
